<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page</title>
    <style>
        p{
            text-align: center;
            font-size: 1.5em;
            font-weight: bold;
            
        }
        h1{
            text-align: center;
            color: #0000ff;
            font-size: 3em;
        }
        a{
            text-decoration: none;
            font-size: large;
            font-weight: bold;
            color: rgb(255, 0, 0);
        }
        button{
            display: block;
            margin: 0 auto;
            width: 120px;
            height: 30px;
        }
    </style>
</head>
<body>
    <h1>Welcome to Home Page</h1>
    <p>The Total Number of Users: <mark><%= count %></mark></p>
    <br><br>
    
    <button><a href="http://localhost:8080/user">User Details</a></button>
</body>
</html>