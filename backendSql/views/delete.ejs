<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete User</title>
    <style>
        .remove{
            color: red;
            font-weight: bolder;
        }
        h2,h3{
            text-align: center;
        }
        .email{
            margin-left: 46em;
        }
    </style>
</head>
<body>
    <h2>Delete User From DataBase</h2> <br><br>

    
    <h3>Enter Correct <mark>PASSWORD</mark> to Delete User: &nbsp;<%=user.username %></h3>
     <form method="post"action="/user/<%=user.id%>/?_method=DELETE">
        <input type="email" name="email" class="email" value="<%= user.email %>" required>  &nbsp; &nbsp;
        <input type="password" name="password" placeholder="Enter Password"> &nbsp; &nbsp;
      <button class="remove">Delete</button>
    </form>
</body>
</html>