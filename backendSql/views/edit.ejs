<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Page</title>
</head>
<body>
    <h1 style="text-align: center;">Edit Users Details</h1>

    <h3>You are about to edit this user: <mark> <%= user.email %>  </mark> </h3>

    <form action="/user/<%=user.id%>?_method=PATCH" method="post">
        <textarea name="username">
            <%=user.username%>
        </textarea>
        <input type="password" name="password" placeholder="Enter password">
        <button>Edit</button>
    </form>

</body>
</html>