<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post in Details</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>See Your Post in Detail</h1>
    <center>Welcome in Your Profile</center>
    <h3>Post id: <%= post.id %></h3>
    <div class="post">
    <img src=" <%= post.image%> " alt="images"  class="profile-img"> &nbsp; &nbsp; &nbsp;       
     <h3 class="username"> @<%=post.username %> </h3>
    <h4 class="caption"> <%= post.caption %> </h4>
    </div>
</body>
</html>