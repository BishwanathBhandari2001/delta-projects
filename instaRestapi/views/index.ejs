<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home page</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body style="background-color: burlywood;">
     
    <h1>Facebok Profile</h1> <br><br>

    <a href="http://localhost:8080/posts/new" style="margin-left: 280px;">Create New Post</a>

   <%  for(post of posts){   %>
    <div class="post">
    <h2>UserName: @<%= post.username %> </h2>
    <h2>Post Id: <%= post.id %> </h2>
    <p> <span style="font-weight: 1000;">Caption:</span> <%= post.caption %></p>
    <img src=" <%= post.image%> " alt="images"  class="profile-img"> &nbsp; &nbsp; &nbsp;
   
   <a href="http://localhost:8080/posts/<%= post.id %>">See in Details</a>
 &nbsp; &nbsp; &nbsp;

   <a href="http://localhost:8080/posts/<%= post.id %>/edit">Edit Post</a> &nbsp; &nbsp; &nbsp;

    <form action="/posts/<%= post.id %>/?_method=DELETE" method="post">
        <button>Delete Post</button>
    </form>

    <hr>
   <% }  %>


</body>
</html>